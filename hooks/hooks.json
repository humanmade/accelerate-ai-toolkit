{
  "description": "Safety guardrails for A/B test mutations. Ensures block content is backed up before test creation and verified after. The command scripts filter by ability name so non-create-ab-test calls pass through silently.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__wordpress__mcp-adapter-execute-ability",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/pre-check-ab-test.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__wordpress__mcp-adapter-execute-ability",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/post-check-ab-test.sh"
          }
        ]
      }
    ]
  }
}
